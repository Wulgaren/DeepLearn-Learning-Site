# Frontend (Vite) – required for the app
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Netlify Functions and Edge (used by dev:netlify and production)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
GROQ_API_KEY=your-groq-api-key

# Europeana Search API (Art tab — server-side only; get a key at https://pro.europeana.eu/page/apis )
EUROPEANA_API_KEY=your-europeana-api-key
